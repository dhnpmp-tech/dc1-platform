# DC1 LLM Inference Worker — vLLM serving (OpenAI-compatible)
# Build args let CI publish per-template instant-tier images with one Dockerfile.
ARG BASE_IMAGE=dc1/base-worker:latest
FROM ${BASE_IMAGE}

USER root

# vLLM + HuggingFace tooling
RUN pip3 install --no-cache-dir \
    vllm \
    transformers \
    accelerate \
    sentencepiece \
    protobuf \
    huggingface_hub

# Instant tier: pre-bake the selected model into the worker image.
# Build with --build-arg SKIP_MODEL_PREBAKE=1 to skip (CI smoke or slim builds).
ARG SKIP_MODEL_PREBAKE=0
ARG PREBAKE_MODEL=nvidia/Nemotron-Mini-4B-Instruct
ARG INSTANT_TEMPLATE_ID=nemotron-nano
ENV PREBAKE_MODEL=${PREBAKE_MODEL}
ENV DC1_INSTANT_TEMPLATE_ID=${INSTANT_TEMPLATE_ID}
ENV HF_HOME=/opt/dcp/model-cache/hf
RUN if [ "$SKIP_MODEL_PREBAKE" != "1" ]; then \
      python3 -c "\
from huggingface_hub import snapshot_download; \
import os; \
snapshot_download( \
    repo_id=os.environ.get('PREBAKE_MODEL', 'nvidia/Nemotron-Mini-4B-Instruct'), \
    cache_dir='/opt/dcp/model-cache/hf', \
    local_dir_use_symlinks=False, \
    resume_download=True \
); \
print('Instant-tier model pre-baked.')"; \
    else \
      echo "SKIP_MODEL_PREBAKE=1 — skipping weight pre-bake"; \
    fi

USER dcp:dcp

LABEL dc1.worker.type="llm-inference"
LABEL dc1.worker.version="2.0"
LABEL dc1.worker.engine="vllm"
LABEL dc1.worker.instant-model="${PREBAKE_MODEL}"
LABEL dc1.worker.instant-template-id="${INSTANT_TEMPLATE_ID}"

CMD ["python", "/dc1/job/task.py"]
