# DCP Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Core ──────────────────────────────────────────────────────────────────────
DC1_ADMIN_TOKEN=change_me_min_32_chars_random
DC1_HMAC_SECRET=change_me_min_32_chars_random

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ── Database ──────────────────────────────────────────────────────────────────
DC1_DB_PATH=./data/providers.db

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Optional ──────────────────────────────────────────────────────────────────
# DCP_IMAGE_REGISTRY_ALLOWLIST=docker.io,ghcr.io
# DCP_PRIVATE_REGISTRY=
# DCP_IMAGE_APPROVAL_WINDOW_MINUTES=10
# DCP_IMAGE_APPROVAL_MAX_REQUESTS=20

# ── P2P Network (DCP-612) ─────────────────────────────────────────────────────
# Bootstrap node multiaddr — deployed at 76.13.179.86:4001
# DCP_P2P_BOOTSTRAP=/ip4/76.13.179.86/tcp/4001/p2p/12D3KooWDYjwG3BrC8pVoGVFw3efshDxDKgTWSxqpXxqv6U4bUdc
# P2P_DISCOVERY_ENABLED=true
