{
  "id": "qwen25-7b",
  "name": "Qwen 2.5 7B Instruct",
  "description": "Alibaba Qwen 2.5 7B Instruct — strong multilingual model with Arabic support. OpenAI-compatible serving via vLLM. Fits in 16 GB VRAM.",
  "image": "dc1/llm-worker:latest",
  "job_type": "llm-inference",
  "env_vars": [
    { "key": "MODEL_ID", "label": "Model ID (HuggingFace)", "default": "Qwen/Qwen2.5-7B-Instruct", "required": true },
    { "key": "MAX_MODEL_LEN", "label": "Max context length (tokens)", "default": "32768", "required": false },
    { "key": "DTYPE", "label": "Weight dtype", "default": "float16", "required": false },
    { "key": "MAX_TOKENS", "label": "Max output tokens", "default": "512", "required": false },
    { "key": "TEMPERATURE", "label": "Sampling temperature", "default": "0.7", "required": false }
  ],
  "params": {
    "model": "Qwen/Qwen2.5-7B-Instruct",
    "prompt": "أخبرني عن الذكاء الاصطناعي في المملكة العربية السعودية.",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "model_cache": {
    "mount_path": "/opt/dcp/model-cache",
    "default_policy": "hot",
    "behavior": "Hot cache — weight shards kept pinned for low-latency Arabic/multilingual workloads. Model size ~15 GB."
  },
  "example_io": {
    "input": {
      "job_type": "llm-inference",
      "duration_minutes": 60,
      "params": {
        "model": "Qwen/Qwen2.5-7B-Instruct",
        "prompt": "Summarize the following Arabic text and respond in Arabic.",
        "max_tokens": 1024,
        "temperature": 0.7
      }
    },
    "output": {
      "type": "text",
      "model": "Qwen/Qwen2.5-7B-Instruct",
      "status": "completed",
      "tokens_generated": 1024
    }
  },
  "min_vram_gb": 16,
  "estimated_price_sar_per_hour": 9.0,
  "tags": ["llm", "inference", "qwen", "arabic", "multilingual", "openai-compatible"],
  "sort_order": 4,
  "icon": "🌐",
  "difficulty": "easy",
  "tier": "cached",
  "tier_notes": "Cached tier — 32k context window with strong Arabic language performance. HuggingFace weights cached hot on provider disk."
}
