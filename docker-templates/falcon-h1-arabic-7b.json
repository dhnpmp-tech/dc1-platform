{
  "id": "falcon-h1-arabic-7b",
  "name": "Falcon-H1 7B Arabic Instruct",
  "description": "TII Falcon-H1-7B-Instruct tuned for high-quality Arabic generation and enterprise inference workloads.",
  "image": "dc1/llm-worker:latest",
  "job_type": "llm-inference",
  "env_vars": [
    { "key": "MODEL_ID", "label": "Model ID (HuggingFace)", "default": "tiiuae/Falcon-H1-7B-Instruct", "required": true },
    { "key": "MAX_MODEL_LEN", "label": "Max context length (tokens)", "default": "4096", "required": false },
    { "key": "DTYPE", "label": "Weight dtype", "default": "float16", "required": false },
    { "key": "MAX_TOKENS", "label": "Max output tokens", "default": "512", "required": false },
    { "key": "TEMPERATURE", "label": "Sampling temperature", "default": "0.7", "required": false }
  ],
  "params": {
    "model": "tiiuae/Falcon-H1-7B-Instruct",
    "prompt": "اكتب ملخصاً تنفيذياً قصيراً لخطة منتج تقني.",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "model_cache": {
    "mount_path": "/opt/dcp/model-cache",
    "default_policy": "hot",
    "behavior": "Hot cache — Falcon-H1-7B weights are pinned for low-latency Arabic inference."
  },
  "example_io": {
    "input": {
      "job_type": "llm-inference",
      "duration_minutes": 60,
      "params": {
        "model": "tiiuae/Falcon-H1-7B-Instruct",
        "prompt": "حلل تأثير الذكاء الاصطناعي على تجربة العملاء في التجارة الإلكترونية.",
        "max_tokens": 1024,
        "temperature": 0.7
      }
    },
    "output": {
      "type": "text",
      "model": "tiiuae/Falcon-H1-7B-Instruct",
      "language": "ar",
      "status": "completed"
    }
  },
  "min_vram_gb": 16,
  "estimated_price_sar_per_hour": 12.0,
  "tags": ["llm", "arabic", "falcon", "tii", "inference", "mena"],
  "sort_order": 8,
  "icon": "🦅",
  "difficulty": "easy",
  "tier": "cached",
  "pdpl_compliant": true
}
