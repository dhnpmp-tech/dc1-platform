{
  "id": "allam-7b-instruct",
  "name": "ALLaM-7B Arabic Enterprise",
  "description": "SDAIA HUMAIN ALLaM-7B Instruct — Saudi Arabia's state-of-the-art Arabic LLM. #1 globally on Arabic MMLU benchmark.",
  "image": "dc1/llm-worker:latest",
  "job_type": "llm-inference",
  "env_vars": [
    { "key": "MODEL_ID", "label": "Model ID (HuggingFace)", "default": "HUMAIN-AI/ALLaM-7B-Instruct", "required": true },
    { "key": "MAX_MODEL_LEN", "label": "Max context length (tokens)", "default": "8192", "required": false },
    { "key": "DTYPE", "label": "Weight dtype", "default": "float16", "required": false },
    { "key": "MAX_TOKENS", "label": "Max output tokens", "default": "512", "required": false },
    { "key": "TEMPERATURE", "label": "Sampling temperature", "default": "0.7", "required": false }
  ],
  "params": {
    "model": "HUMAIN-AI/ALLaM-7B-Instruct",
    "prompt": "مرحباً، كيف يمكنني مساعدتك اليوم؟",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "model_cache": {
    "mount_path": "/opt/dcp/model-cache",
    "default_policy": "hot",
    "behavior": "Hot cache — ALLaM-7B weights (~16GB) kept pinned for instant Arabic enterprise responses."
  },
  "example_io": {
    "input": {
      "job_type": "llm-inference",
      "duration_minutes": 60,
      "params": {
        "model": "HUMAIN-AI/ALLaM-7B-Instruct",
        "prompt": "ما هي أهم مبادرات الرؤية 2030 في قطاع التقنية؟",
        "max_tokens": 1024,
        "temperature": 0.7
      }
    },
    "output": {
      "type": "text",
      "model": "HUMAIN-AI/ALLaM-7B-Instruct",
      "language": "ar",
      "status": "completed"
    }
  },
  "min_vram_gb": 20,
  "estimated_price_sar_per_hour": 12.0,
  "tags": ["llm", "arabic", "allam", "sdaia", "humain", "enterprise", "saudi", "inference", "mena", "vision-2030"],
  "sort_order": 7,
  "icon": "🏛️",
  "difficulty": "easy",
  "tier": "cached",
  "pdpl_compliant": true
}
