{
  "id": "mistral-7b",
  "name": "Mistral 7B Instruct",
  "description": "Mistral AI 7B Instruct — strong reasoning and coding performance in the 7B class. OpenAI-compatible serving via vLLM. Fits in 16 GB VRAM with sliding-window attention up to 32k tokens.",
  "image": "dc1/llm-worker:latest",
  "job_type": "llm-inference",
  "env_vars": [
    {
      "key": "MODEL_ID",
      "label": "Model ID (HuggingFace)",
      "default": "mistralai/Mistral-7B-Instruct-v0.2",
      "required": true
    },
    {
      "key": "MAX_MODEL_LEN",
      "label": "Max context length (tokens)",
      "default": "8192",
      "required": false
    },
    {
      "key": "DTYPE",
      "label": "Weight dtype",
      "default": "float16",
      "required": false
    },
    {
      "key": "MAX_TOKENS",
      "label": "Max output tokens",
      "default": "512",
      "required": false
    },
    {
      "key": "TEMPERATURE",
      "label": "Sampling temperature",
      "default": "0.7",
      "required": false
    }
  ],
  "params": {
    "model": "mistralai/Mistral-7B-Instruct-v0.2",
    "prompt": "You are a helpful assistant. Describe the benefits of GPU compute marketplaces in 3 sentences.",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "model_cache": {
    "mount_path": "/opt/dcp/model-cache",
    "default_policy": "hot",
    "behavior": "Hot cache — weights kept pinned on provider disk for fast cold-start. No download delay after first pull (~14 GB)."
  },
  "example_io": {
    "input": {
      "job_type": "llm-inference",
      "duration_minutes": 60,
      "params": {
        "model": "mistralai/Mistral-7B-Instruct-v0.2",
        "prompt": "Explain transformer attention mechanisms.",
        "max_tokens": 512,
        "temperature": 0.7
      }
    },
    "output": {
      "type": "text",
      "model": "mistralai/Mistral-7B-Instruct-v0.2",
      "status": "completed",
      "tokens_generated": 512
    }
  },
  "min_vram_gb": 16,
  "estimated_price_sar_per_hour": 8,
  "tags": [
    "llm",
    "inference",
    "mistral",
    "openai-compatible",
    "coding",
    "reasoning",
    "arabic"
  ],
  "sort_order": 5,
  "icon": "🌊",
  "difficulty": "easy",
  "tier": "cached",
  "tier_notes": "Cached tier — HuggingFace weights pulled on first run and kept hot on provider disk. Cold start ~2 min on first run (~14 GB), ~10 s thereafter. Supports sliding-window attention for contexts up to 32k tokens."
}
