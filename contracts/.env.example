# ─── DC1 Contracts — Environment Variables ────────────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git.

# Deployer wallet private key (without 0x prefix)
# Use a dedicated deployment wallet — NOT your personal wallet
PRIVATE_KEY=your_private_key_here

# USDC token address on target network
# Base Sepolia (testnet): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# DC1 backend oracle address (signs job-completion proofs)
# This is the Ethereum address corresponding to the private key used in backend/src/services/escrow.js
ORACLE_ADDRESS=your_oracle_address_here

# Basescan API key (for contract verification)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here
